{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/pub/(.*)", "destination": "/api/publisher" },
    { "source": "/api/admin/publishers", "destination": "/api/publisher" },
    { "source": "/api/admin/pub-transactions", "destination": "/api/publisher" },
    { "source": "/api/(.*)", "destination": "/api/handler" }
  ]
}
